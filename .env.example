# Copy this file to .env.local and fill in real values.
# .env.local is gitignored (see the "*.local" rule in .gitignore) - never commit real keys.

# Supabase project settings -> API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Comma-separated list of Google account emails allowed to use the admin panel.
# This is a client-side hint only (used to redirect non-admins away quickly) -
# the real enforcement happens in Supabase via the `admins` table + RLS policies,
# see supabase/schema.sql.
VITE_ADMIN_EMAILS=you@example.com
